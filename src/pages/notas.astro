---
import Base from "@/layouts/Base.astro";
import {
	presentationSlides,
	integrantes,
	DOCUMENT_URL,
} from "@/data/presentation";

const totalSeconds = presentationSlides.reduce((a, s) => a + s.note.seconds, 0);

function fmt(seconds: number) {
	const m = Math.floor(seconds / 60);
	const s = seconds % 60;
	return m > 0 ? `${m} min ${s ? `${s} s` : ""}`.trim() : `${s} s`;
}

const perPersona = integrantes.map((_, i) => {
	const persona = i + 1;
	const slides = presentationSlides
		.map((s, idx) => ({ s, n: idx + 1 }))
		.filter((x) => x.s.note.persona === persona);
	const seconds = slides.reduce((a, x) => a + x.s.note.seconds, 0);
	return { persona, name: integrantes[i], slides: slides.map((x) => x.n), seconds };
});
---

<Base title="Notas del orador · Sanatorio Bernal">
	<main class="notes">
		<header class="notes-head">
			<a class="back" href="/">
				<span aria-hidden="true">←</span> Volver a la presentación
			</a>
			<p class="kicker">Notas del orador</p>
			<h1>Diagnóstico y Propuesta de Mejora para Sanatorio Bernal</h1>
			<p class="sub">
				Guion de alto nivel: qué mencionar en cada diapositiva. Tiempo total
				estimado <strong>{fmt(totalSeconds)}</strong> · {presentationSlides.length} diapositivas · {integrantes.length} integrantes.
			</p>
		</header>

		<section class="people">
			{
				perPersona.map((p) => (
					<div class="person">
						<span class="person-no">{p.persona}</span>
						<div>
							<h3>{p.name}</h3>
							<p>
								Diapositivas {p.slides.join(", ")} · ~{fmt(p.seconds)}
							</p>
						</div>
					</div>
				))
			}
		</section>

		<ol class="slides">
			{
				presentationSlides.map((slide, i) => {
					const n = i + 1;
					const personaLabel = integrantes[slide.note.persona - 1] ?? `Integrante #${slide.note.persona}`;
					return (
						<li class="note">
							<div class="note-meta">
								<span class="note-n">{String(n).padStart(2, "0")}</span>
								<span class="note-persona">
									{personaLabel}
								</span>
								<span class="note-time">~{fmt(slide.note.seconds)}</span>
								<a class="note-link" href={n === 1 ? "/" : `/${n}`}>
									Ir a la diapositiva ↗
								</a>
							</div>
							<p class="note-eyebrow">{slide.eyebrow}</p>
							<h2>{slide.title}</h2>
							<ul>
								{slide.note.points.map((pt) => (
									<li>{pt}</li>
								))}
							</ul>
						</li>
					);
				})
			}
		</ol>

		<footer class="notes-foot">
			<a href={DOCUMENT_URL}>Documento fuente ↗</a>
		</footer>
	</main>
</Base>

<style>
	.notes {
		max-width: 60rem;
		margin: 0 auto;
		padding: clamp(1.5rem, 5vw, 3.5rem) clamp(1rem, 5vw, 2rem) 5rem;
		color: #252b45;
	}
	.back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.9rem;
		color: #24695f;
	}
	.back:hover { text-decoration: underline; }
	.notes-head { border-bottom: 1px solid #d6e3df; padding-bottom: 2rem; margin-bottom: 2rem; }
	.kicker {
		margin: 1.4rem 0 0.6rem;
		font-size: 0.8rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase;
		color: #2f7f73;
	}
	.notes-head h1 { margin: 0 0 0.8rem; font-size: clamp(1.6rem, 4vw, 2.4rem); line-height: 1.1; letter-spacing: -0.02em; }
	.sub { margin: 0; color: #596176; font-size: 1.05rem; line-height: 1.5; max-width: 48rem; }
	.sub strong { color: #1e554f; }

	.people {
		display: grid; grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
		gap: 0.8rem; margin-bottom: 2.6rem;
	}
	.person {
		display: flex; gap: 0.8rem; align-items: center;
		background: #f4faf8; border: 1px solid #dfeeea; border-radius: 0.9rem; padding: 0.9rem 1rem;
	}
	.person-no {
		flex: none; display: grid; place-items: center;
		width: 2rem; height: 2rem; border-radius: 999px;
		background: #24695f; color: #fff; font-weight: 800; font-size: 0.9rem;
	}
	.person h3 { margin: 0 0 0.15rem; font-size: 1rem; }
	.person p { margin: 0; font-size: 0.82rem; color: #596176; }

	.slides { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1.2rem; }
	.note {
		background: #fff; border: 1px solid #d6e3df; border-left: 4px solid #24695f;
		border-radius: 0.9rem; padding: 1.3rem 1.5rem;
	}
	.note-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.8rem; margin-bottom: 0.6rem; }
	.note-n { font-weight: 800; color: #2f7f73; font-size: 0.95rem; }
	.note-persona { font-weight: 700; font-size: 0.85rem; color: #1e554f; }
	.note-time {
		font-size: 0.78rem; font-weight: 600; color: #1e554f;
		background: #dfeeea; border-radius: 999px; padding: 0.15rem 0.6rem;
	}
	.note-link { margin-left: auto; font-size: 0.82rem; font-weight: 600; color: #24695f; text-decoration: none; }
	.note-link:hover { text-decoration: underline; }
	.note-eyebrow { margin: 0; font-size: 0.74rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #559c8e; }
	.note h2 { margin: 0.2rem 0 0.7rem; font-size: 1.15rem; line-height: 1.25; letter-spacing: -0.01em; }
	.note ul { margin: 0; padding-left: 1.1rem; display: flex; flex-direction: column; gap: 0.35rem; }
	.note li { font-size: 0.95rem; line-height: 1.45; color: #4f5869; }

	.notes-foot { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid #d6e3df; }
	.notes-foot a { color: #24695f; font-weight: 600; text-decoration: none; }
	.notes-foot a:hover { text-decoration: underline; }
</style>
